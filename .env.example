# Copia a .env y ajusta valores. No subas .env al repositorio.

# Obligatorio en producción: cadena aleatoria de al menos 32 caracteres.
SESSION_SECRET=cambia_esto_por_un_secreto_largo_de_al_menos_32_caracteres

# Primer usuario (se crea solo si la base de datos está vacía).
# Usa tu correo real para entrar desde el formulario de login.
ADMIN_EMAIL=tu@correo.com
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contraseña

# true solo detrás de HTTPS (cookies Secure).
COOKIE_SECURE=false

# true = cualquiera puede crear cuenta en /register.html
ALLOW_REGISTRATION=false
